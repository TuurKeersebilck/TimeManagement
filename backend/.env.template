# TimeManagement API Environment Variables
# -------------------------------------------------

# CORS — comma-separated list of allowed frontend origins
# Required in production. Defaults to http://localhost:5173 in Development.
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database Connection
# ------------------
# PostgreSQL connection string (Npgsql format)
CONNECTION_STRING=Host=yourhost;Database=postgres;Username=postgres;Password=yourpassword;Port=5432

# JWT Authentication Configuration
JWT_SECRET=your_very_secure_random_string_here_at_least_32_chars

# ISSUER and AUDIENCE
JWT_ISSUER=TimeManagementAPI
JWT_AUDIENCE=TimeManagementAPI

# Token expiration time in minutes
JWT_EXPIRY_MINUTES=60

# Email (MailKit / Gmail App Password)
# ------------------------------------
# Generate an App Password at: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=you@gmail.com

# Frontend URL — used in password reset links
APP_URL=http://localhost:5173

# Backend URL — used in adjustment request approval email links
# Set this to the public URL of the backend API (no trailing slash)
# Falls back to the incoming request's scheme+host if not set (works for most deployments)
BACKEND_URL=https://your-backend-domain.com

# Additional Configuration
# ----------------------
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=https://localhost:7055;http://localhost:5055