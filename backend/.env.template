# Copy this file to .env and fill in all values before running the backend locally.
# Generate secrets with: openssl rand -base64 48

# Database connection string (Npgsql format)
CONNECTION_STRING=Host=localhost;Database=logr;Username=postgres;Password=changeme;Port=5432

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_ISSUER=TimeManagementAPI
JWT_AUDIENCE=TimeManagementAPI
JWT_EXPIRY_MINUTES=60

# CORS — comma-separated list of allowed frontend origins
# Defaults to http://localhost:5173 in Development if not set
CORS_ORIGINS=http://localhost:5173

# URLs — used in email links (no trailing slash)
APP_URL=http://localhost:5173
BACKEND_URL=http://localhost:7055

# SMTP (Mailjet SMTP relay)
# Find your API key and secret at: app.mailjet.com → Account → API Keys
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USER=your_mailjet_api_key
SMTP_PASS=your_mailjet_secret_key
SMTP_FROM=you@yourdomain.com

# ASP.NET Core (optional overrides)
# ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=https://localhost:7055;http://localhost:5055
