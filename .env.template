# Copy this file to .env and fill in all values before running docker compose.
# Generate secrets with: openssl rand -base64 48

# PostgreSQL
POSTGRES_DB=logr
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Backend connection string — host must match the db service name
CONNECTION_STRING=Host=db;Database=logr;Username=postgres;Password=changeme

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_ISSUER=TimeManagementAPI
JWT_AUDIENCE=TimeManagementAPI
JWT_EXPIRY_MINUTES=60

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://yourdomain.com

# URLs — used in email links (no trailing slash)
APP_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# SMTP (Gmail app password or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=you@gmail.com
